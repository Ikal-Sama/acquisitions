# .env.production — values consumed by docker-compose.prod.yml
# Production secrets. NEVER commit this file.

# --- Server ---
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# --- Neon Cloud (serverless) ---
# The full connection string from the Neon dashboard:
#   Project → Connection Details → "Pooled connection" or "Direct connection"
# Example:
#   postgres://neondb_owner:<password>@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- App secrets ---
JWT_SECRET=
ARCJET_KEY=
