# .env.development — values consumed by docker-compose.dev.yml
# Copy to .env.development and fill in real values from https://console.neon.tech

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Neon Local (proxy that runs in Docker) ---
# Create an API key at:  https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=

# Find the project ID on the Neon dashboard: Settings → General
NEON_PROJECT_ID=

# The branch that Neon Local will use as the parent for an ephemeral dev branch.
# This is typically your project's default (main) branch.
# When set, an ephemeral branch is created on container start and destroyed on stop.
PARENT_BRANCH_ID=

# --- App config ---
# Application-level secrets (NOT the DB URL — that is set inside the compose file)
ARCJET_KEY=
